# ccxt-gateway environment variables

# Server
CCXT_GATEWAY_SERVER_HOST=0.0.0.0
CCXT_GATEWAY_SERVER_PORT=8000
CCXT_GATEWAY_SERVER_DEBUG=false
CCXT_GATEWAY_SERVER_USE_SSL=false
CCXT_GATEWAY_SERVER_USE_GRANIAN=false

# ZeroMQ
CCXT_GATEWAY_ZMQ_BROKER_ADDRESS=tcp://127.0.0.1:5555
CCXT_GATEWAY_ZMQ_TIMEOUT_MS=30000

# Process Manager
CCXT_GATEWAY_PM_MAX_RSS_MB=512
CCXT_GATEWAY_PM_CHECK_INTERVAL=30
CCXT_GATEWAY_PM_AUTO_RESTART=true
CCXT_GATEWAY_PM_MAX_RESTARTS_PER_HOUR=5

# Updates
CCXT_GATEWAY_UPDATE_CHECK_INTERVAL_HOURS=24
CCXT_GATEWAY_UPDATE_AUTO_UPDATE=false
